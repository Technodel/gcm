# Copy this to .env and fill in your values on the VPS

# PostgreSQL connection string
DATABASE_URL=postgresql://tcm_user:yourpassword@localhost:5432/competitor_monitor

# JWT secret — change this to a long random string on production
JWT_SECRET=change_this_to_a_random_64_char_string_on_your_vps

# Node environment
NODE_ENV=production

# Port (default 8515)
PORT=8515

# ─── LLM providers (fallback chain: Groq → OpenRouter → DeepSeek) ─────────────
# All are optional — the scraper falls back to CSS heuristics if none are set.

# 1. Groq — fastest (llama-3.1-8b-instant, free tier)
#    https://console.groq.com
GROQ_API_KEY=gsk_your_groq_key_here

# 2. OpenRouter — high-quality fallback (deepseek/deepseek-chat)
#    https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key_here

# 3. DeepSeek — direct API fallback (deepseek-chat)
#    https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-your_deepseek_key_here

# NOTE: Voyage AI was evaluated but is embeddings-only (not a text-generation
# model) so it cannot extract product data and is intentionally excluded.
