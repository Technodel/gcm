# Copy this to .env and fill in your values on the VPS

# PostgreSQL connection string
DATABASE_URL=postgresql://tcm_user:yourpassword@localhost:5432/competitor_monitor

# JWT secret — change this to a long random string on production
JWT_SECRET=change_this_to_a_random_64_char_string_on_your_vps

# Node environment
NODE_ENV=production

# Port (default 8515)
PORT=8515
